# set the command prompt
function set_command_prompt() {
  # source colors from another file
  source ~/.bashrc.d/baseTheme

  # set user @ host prompt
  local user_details="${BOLD}${BRIGHT_CYAN}\u${RESET}${BRIGHT_BLUE}@\h"

  # set path prompt
  local path_details="${BOLD}${BRIGHT_ORANGE}\w"

  # set return code prompt
  local return_details="\$(if [ \$? -eq 0 ]; then echo \"${BRIGHT_GREEN}\"; else echo \"${BRIGHT_RED}\"; fi)→"
 
  # set prompt reset
  local reset_details="${RESET}"

  PS1="${user_details} ${path_details} ${return_details} ${reset_details}"
}

