#!/bin/bash

# runs bootstrap script if it exists ./bootstrap-<hostname>.sh
BOOTSTRAP_SCRIPT=$(dirname $(readlink -f $0))/bootstrap-$(uname -n).sh
[[ ! -f ${BOOTSTRAP_SCRIPT} ]] && echo "No bootstrap script for host: $(uname -n), ${BOOTSTRAP_SCRIPT} does not exist" && return 1
source ${BOOTSTRAP_SCRIPT}
